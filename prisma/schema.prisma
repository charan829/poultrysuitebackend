generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  FARMER
  CUSTOMER
  ADMIN
}

enum BatchType {
  BROILER
  LAYER
  DUCK
  TURKEY
  EGGS
}

enum RequestStatus {
  AVAILABLE
  SOLD
  CANCELLED
}

enum OrderStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  phone     String?
  role      Role     @default(FARMER)
  status    UserStatus @default(ACTIVE)
  createdAt DateTime @default(now())
  
  // Relations
  farm          Farm?
  orders        Order[]
  reviews       Review[]        @relation("CustomerReviews")
  conversations Conversation[]  @relation("CustomerConversations")
  sentMessages  Message[]       @relation("SentMessages")
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

model Farm {
  id          Int      @id @default(autoincrement())
  name        String
  location    String?
  ownerId     Int      @unique
  owner       User     @relation(fields: [ownerId], references: [id])
  createdAt   DateTime @default(now())
  images      String[] @default([])

  // Relations
  batches       Batch[]
  inventory     Inventory?
  expenses      Expense[]
  products      ProductRequest[]
  reviews       Review[]
  conversations Conversation[]
}

model Batch {
  id          Int       @id @default(autoincrement())
  farmId      Int
  farm        Farm      @relation(fields: [farmId], references: [id])
  type        BatchType
  count       Int
  ageDays     Int       @default(0)
  mortality   Int       @default(0)
  startedAt   DateTime  @default(now())

  // Detail records
  mortalityRecords    MortalityRecord[]
  vaccinationRecords  VaccinationRecord[]
  feedLogs            FeedLog[]
}

model MortalityRecord {
  id        Int      @id @default(autoincrement())
  batchId   Int
  batch     Batch    @relation(fields: [batchId], references: [id])
  count     Int
  cause     String   // Unknown, Disease, Injury, etc.
  date      DateTime @default(now())
}

model VaccinationRecord {
  id            Int      @id @default(autoincrement())
  batchId       Int
  batch         Batch    @relation(fields: [batchId], references: [id])
  name          String   // Newcastle Disease, Gumboro, etc.
  scheduledDate DateTime
  status        String   @default("Upcoming") // Upcoming, Completed, Missed
}

model FeedLog {
  id       Int      @id @default(autoincrement())
  batchId  Int
  batch    Batch    @relation(fields: [batchId], references: [id])
  amountKg Float
  date     DateTime @default(now())
  notes    String?
}

model Inventory {
  id          Int      @id @default(autoincrement())
  farmId      Int      @unique
  farm        Farm     @relation(fields: [farmId], references: [id])
  feedKg      Float    @default(0.0)
  medicineCount Int    @default(0)
  updatedAt   DateTime @updatedAt
}

model Expense {
  id          Int      @id @default(autoincrement())
  farmId      Int
  farm        Farm     @relation(fields: [farmId], references: [id])
  category    String   // Feed, Medicine, Labor, etc.
  amount      Float
  date        DateTime @default(now())
  description String?
}

model ProductRequest {
  id          Int           @id @default(autoincrement())
  farmId      Int
  farm        Farm          @relation(fields: [farmId], references: [id])
  type        String        // What are they selling? (e.g. Broilers, Eggs)
  quantity    Int
  pricePerUnit Float
  status      RequestStatus @default(AVAILABLE)
  createdAt   DateTime      @default(now())

  order       Order?
}

model Order {
  id            Int         @id @default(autoincrement())
  customerId    Int
  customer      User        @relation(fields: [customerId], references: [id])
  productId     Int         @unique
  product       ProductRequest @relation(fields: [productId], references: [id])
  status        OrderStatus @default(PENDING)
  totalPrice    Float
  createdAt     DateTime    @default(now())
  dueDate       DateTime?

  // Farmer direct sale fields (optional for marketplace orders)
  buyerName     String?
  notes         String?
  paymentStatus String?     @default("Paid") // Paid, Pending, Partial

    review        Review?
}

model Review {
  id         Int      @id @default(autoincrement())
  farmId     Int
  farm       Farm     @relation(fields: [farmId], references: [id])
  customerId Int
  customer   User     @relation("CustomerReviews", fields: [customerId], references: [id])
  orderId    Int      @unique
  order      Order    @relation(fields: [orderId], references: [id])
  rating     Int
  comment    String?
  images     String[] @default([])
  createdAt  DateTime @default(now())
}

model Conversation {
  id         Int       @id @default(autoincrement())
  farmId     Int
  farm       Farm      @relation(fields: [farmId], references: [id])
  customerId Int
  customer   User      @relation("CustomerConversations", fields: [customerId], references: [id])
  messages   Message[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([farmId, customerId])
}

model Message {
  id             Int          @id @default(autoincrement())
  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  senderId       Int
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
  content        String
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
}
